{
  "installCommand": "npm install --legacy-peer-deps && cd apps/user && npm install --legacy-peer-deps",
  "buildCommand": "cd apps/user && npm run build",
  "outputDirectory": "apps/user/.next",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/execute-pending-orders",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/settle-due-stakings",
      "schedule": "*/5 * * * *"
    }
  ]
}
